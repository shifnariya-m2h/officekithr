{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "officekithr",
  "compatibility_date": "2026-06-17",
  // Static Vite build output — not Next.js / OpenNext.
  // Build with: npm run build (prerender on by default) or npm run deploy:cloudflare
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
