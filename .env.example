# =============================================================================
# OfficeKit HR — environment template
# Copy to .env and adjust. Never commit .env (see .gitignore).
# =============================================================================

# --- Site (used by SEO, sitemap build, canonical URLs) ---
VITE_SITE_URL=https://www.officekithr.com

# --- APIs (browser → your server PHP proxies on production) ---
VITE_LEADS_API_URL=/api/leads.php
VITE_HR_POPUP_API_URL=/api/hr-popup.php
VITE_BLOG_API_URL=https://api.officekithr.com/api/blogs

# --- Analytics (loaded only after cookie consent) ---
VITE_GA_MEASUREMENT_ID=G-J60WZ10KBF
VITE_GTAG_ID=GT-KDD8X4P9
VITE_GOOGLE_ADS_ID=AW-17365780413
VITE_GOOGLE_ADS_CONVERSION=AW-17365780413/MAzACIaay74bEL2P09hA

# --- Tawk.to live chat (loaded after consent + idle delay) ---
VITE_TAWK_PROPERTY_ID=68bbb72167c586192c667ccf
VITE_TAWK_WIDGET_ID=1j4ek6n8v

# --- Local dev toggles (optional) ---
# Quieter console: disable third-party chat widget
VITE_DISABLE_TAWK=true
# Skip gtag in dev (analytics still respect cookie consent when false)
# VITE_DISABLE_ANALYTICS=true

# =============================================================================
# Server-only — cPanel / hosting Environment Variables (never commit real values)
# Copy HR_GOOGLE_SHEET_URL from your local .env when configuring production.
# =============================================================================
# SYNCORA_API_KEY=sk_live_...
# HR_GOOGLE_SHEET_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
